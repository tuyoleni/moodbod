{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "target": "es6",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "app/**/*.tsx",
    "app/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}